{
  "name": "comsatel",
  "version": "1.0.0",
  "description": "Comsatel WordPress Theme",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@wordpress/scripts": "^19.2.2",
    "autoprefixer": "^10.4.22",
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "dir-archiver": "^1.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "tailwindcss-motion": "^1.1.1",
    "vite": "^5.4.0"
  },
  "scripts": {
    "start": "concurrently \"vite build --watch\" \"browser-sync start --proxy 'comsatel-nerd.local' --files 'dist/**/*' --no-open\"",
    "dev": "vite build --watch",
    "build": "vite build",
    "lint:js": "wp-scripts lint-js 'js/*.js'",
    "bundle": "dir-archiver --src . --dest ../_s.zip --exclude .DS_Store .stylelintrc.json .eslintrc .git .gitattributes .github .gitignore README.md node_modules vendor package-lock.json package.json dist"
  },
  "dependencies": {
    "swiper": "^12.0.3"
  }
}
